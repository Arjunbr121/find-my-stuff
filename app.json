{
  "expo": {
    "name": "Find My Stuff",
    "slug": "find-my-stuff",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/appLogo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.findmystuff.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Find My Stuff uses your camera to take photos of items you want to track.",
        "NSPhotoLibraryUsageDescription": "Find My Stuff accesses your photos to add images to tracked items.",
        "NSPhotoLibraryAddUsageDescription": "Find My Stuff saves photos to your library.",
        "NSFaceIDUsageDescription": "Find My Stuff uses Face ID to unlock the app securely."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.findmystuff.app",
      "versionCode": 2,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/appLogo.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Find My Stuff to access your camera to take photos of items."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Find My Stuff to access your photos to select images of items."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Find My Stuff to use Face ID to unlock the app."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "e3d6d673-e26f-4658-be67-76293fed4e8a"
      }
    }
  }
}