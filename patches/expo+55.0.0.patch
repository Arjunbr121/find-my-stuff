+export async function convertReadableStreamToUint8ArrayAsync(stream) {
+    const reader = stream.getReader();
+    const chunks = [];
+    let totalLength = 0;
+    // Read all chunks from the stream
+    while (true) {
+        const { done, value } = await reader.read();
+        if (done)
