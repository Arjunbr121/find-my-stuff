{
  "expo": {
    "name": "Find My Stuff",
    "slug": "find-my-stuff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4ECDC4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.findmystuff.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of items you want to track.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select photos of items you want to track.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4ECDC4",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.findmystuff.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/appLogo.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Find My Stuff to access your camera to take photos of items."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Find My Stuff to access your photos to select images of items."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "e3d6d673-e26f-4658-be67-76293fed4e8a"
      }
    }
  }
}
